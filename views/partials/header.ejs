<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Office 365 Toolkit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        .nav-link.active {
            color: white !important;
            font-weight: bold;
        }
        .dropdown-menu {
            background-color: #343a40;
            border-color: #454d55;
        }
        .dropdown-item {
            color: #adb5bd;
        }
        .dropdown-item:hover, .dropdown-item:focus {
            color: #fff;
            background-color: #454d55;
        }
        .dropdown-item.active {
            color: #fff;
            background-color: #007bff;
        }
        @media (min-width: 992px) {
            .dropdown:hover .dropdown-menu {
                display: block;
            }
        }
    </style>
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Bitcircuit - Office 365 Toolkit</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <% if (locals.isAuthenticated) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle <%= ['pst-manager', 'pst-migration'].includes(currentPage) ? 'active' : '' %>" href="#" id="pstToolsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                PST Tools
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="pstToolsDropdown">
                                <li><a class="dropdown-item <%= currentPage === 'pst-manager' ? 'active' : '' %>" href="/pst-manager">PST Manager</a></li>
                                <li><a class="dropdown-item <%= currentPage === 'pst-migration' ? 'active' : '' %>" href="/pst-migration">PST Migration</a></li>
                                <li><a class="dropdown-item <%= currentPage === 'pst-bulkmigration' ? 'active' : '' %>" href="/pst-bulkmigration">PST Bulk Migration</a></li>
                            </ul>
                        </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <% if (locals.isAuthenticated) { %>
                        <li class="nav-item">
                            <span class="nav-link">Angemeldet als: <%= locals.organizationName %></span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/logout">Abmelden</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-4">