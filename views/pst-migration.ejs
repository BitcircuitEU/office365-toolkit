<%- include('partials/header') %>

<h1 class="mb-4">PST Migration</h1>

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <h2>PST-Datei auswählen</h2>
            <form id="pstSelectForm">
                <div class="form-group">
                    <select class="form-control" id="pstFile" name="pstFile">
                        <option value="">Bitte wählen Sie eine PST-Datei</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary mt-2" id="pstStructureButton">Ordnerstruktur anzeigen</button>
            </form>
            <div class="mt-4">
                <h3>PST Ordnerstruktur</h3>
                <div id="pstFolderTree"></div>
            </div>
        </div>
        <div class="col-md-6">
            <h2>Zielpostfach auswählen</h2>
            <form id="targetMailboxForm">
                <div class="form-group">
                    <select class="form-control" id="targetMailbox" name="targetMailbox">
                        <option value="">Bitte wählen Sie ein Zielpostfach</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary mt-2" id="targetStructureButton">Ordnerstruktur anzeigen</button>
            </form>
            <div class="mt-4">
                <h3>Zielpostfach Ordnerstruktur</h3>
                <div id="targetFolderTree"></div>
            </div>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-12">
            <button id="importButton" class="btn btn-primary" style="display: none;">Importieren</button>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col">
            <div id="importProgress" class="progress" style="display: none;">
                <div class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
            </div>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col">
            <div id="importStatus"></div>
        </div>
    </div>
</div>
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="resultToast" class="toast bg-dark text-white" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="toast-header bg-dark text-white">
        <strong class="me-auto">Ergebnis</strong>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
      <div class="toast-body">
      </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/jstree.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/themes/default/style.min.css" />
<script src="/js/pubmigration.js"></script>

<%- include('partials/footer') %>